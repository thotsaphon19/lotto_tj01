# ══════════════════════════════════════════════
# LOTTO-X Backend — Environment Variables
# คัดลอกไฟล์นี้เป็น .env และกรอกค่าให้ครบ
# ══════════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# Anthropic Claude API Key
# สมัครได้ที่ https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CORS — อนุญาต frontend origin
CORS_ORIGIN=http://localhost:3000

# Cache TTL (seconds) — เก็บ cache กี่วินาที
CACHE_TTL=300

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
