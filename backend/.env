# ══════════════════════════════════════════════════════════════
# LOTTO-TJ Backend — Environment Variables  v2.0
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# ⚠️  อย่า commit ไฟล์นี้ขึ้น Git เด็ดขาด!
# ══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# NODE_ENV=production   ← เปลี่ยนตอน deploy จริง

# ── Anthropic Claude API Key ────────────────────────────────
# สมัครได้ที่ https://console.anthropic.com
ANTHROPIC_API_KEY=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
# ── CORS — อนุญาต frontend origin ──────────────────────────
CORS_ORIGIN=http://localhost:3000
# หลาย origin คั่นด้วยจุลภาค: http://localhost:3000,https://yourdomain.com

# ── Cache TTL (seconds) ─────────────────────────────────────
CACHE_TTL=300

# ── Rate Limiting (general API) ────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ══════════════════════════════════════════════════════════════
# AUTH SYSTEM — ระบบเข้าสู่ระบบ + สิทธิ์ผู้ใช้
# ══════════════════════════════════════════════════════════════

# ── JWT / Token ─────────────────────────────────────────────
# Secret สำหรับ sign token — ใช้ random string ยาว ≥ 32 ตัวอักษร
# สร้างได้ด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# อายุ token (มิลลิวินาที) — ค่าเริ่มต้น 24 ชั่วโมง = 86400000
TOKEN_TTL_MS=86400000

# ── Admin Account ───────────────────────────────────────────
# บัญชีผู้ดูแลระบบ — มีสิทธิ์ล็อก/ปลดล็อกระบบ
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
# ⚠️ เปลี่ยนรหัสผ่านก่อน deploy จริงเสมอ!

# ── User Accounts (เพิ่มได้ตามต้องการ) ────────────────────
# Staff / ผู้ใช้ทั่วไป — สิทธิ์ใช้งานปกติ ไม่สามารถล็อกระบบได้
USER1_USERNAME=user1
USER1_PASSWORD=User@1234

USER2_USERNAME=user2
USER2_PASSWORD=User@5678

STAFF_USERNAME=staff
STAFF_PASSWORD=Staff@2026

# ── Login Rate Limit ────────────────────────────────────────
# จำกัดการพยายาม login ผิด — ป้องกัน brute force
LOGIN_RATE_WINDOW_MS=900000
# 900000 ms = 15 นาที
LOGIN_RATE_MAX=10
# ไม่เกิน 10 ครั้งต่อ 15 นาที ต่อ IP

# ══════════════════════════════════════════════════════════════
# SYSTEM LOCK — ล็อก/ปลดล็อกระบบ
# ══════════════════════════════════════════════════════════════

# ล็อกระบบตั้งแต่เริ่ม server (true = ล็อกทันที, false = เปิดปกติ)
SYSTEM_LOCKED_ON_START=false

# ข้อความแสดงเมื่อระบบถูกล็อก (แสดงให้ผู้ใช้เห็น)
SYSTEM_LOCK_DEFAULT_REASON=ระบบปิดปรับปรุงชั่วคราว กรุณาติดต่อผู้ดูแลระบบ

# ══════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════
# ระดับ log: error | warn | info | debug
LOG_LEVEL=info

# บันทึก auth events (login/logout/lock) ลงไฟล์
# AUTH_LOG_FILE=./logs/auth.log
# (comment ออกถ้าไม่ต้องการบันทึกไฟล์)
